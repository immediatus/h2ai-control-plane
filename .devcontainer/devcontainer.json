{
  "name": "H2AI Control Plane",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "${localEnv:USER}",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "TZ": "America/Los_Angeles",
    "TERM": "xterm-256color"
  },

  "remoteEnv": {
    "H2AI_NATS_URL": "nats://nats:4222",
    "H2AI_PROFILE": "a",
    "RUST_LOG": "h2ai=debug,info",
    "RUST_BACKTRACE": "1"
  },

  "forwardPorts": [
    8080,
    9090,
    4222,
    8222
  ],

  "portsAttributes": {
    "8080": { "label": "H2AI API + Merge Authority UI" },
    "9090": { "label": "Prometheus metrics" },
    "4222": { "label": "NATS client" },
    "8222": { "label": "NATS monitoring" }
  },

  "postCreateCommand": "cargo fetch 2>/dev/null || true",
  
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    }
  }
}
